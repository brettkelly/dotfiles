#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
Usage: webopt <input-file> [width] [quality]
  input-file: image path
  width:      max width in px (default: 2000)
  quality:    JPEG quality 1-100 (default: 85)
EOF
}

[[ $# -lt 1 || $# -gt 3 ]] && {
  usage
  exit 1
}

in="$1"
width="${2:-2000}"
quality="${3:-85}"

[[ -f "$in" ]] || {
  echo "Error: file not found: $in" >&2
  exit 1
}
[[ "$width" =~ ^[0-9]+$ ]] || {
  echo "Error: width must be numeric" >&2
  exit 1
}
[[ "$quality" =~ ^[0-9]+$ ]] || {
  echo "Error: quality must be numeric" >&2
  exit 1
}
(( quality >= 1 && quality <= 100 )) || {
  echo "Error: quality must be 1-100" >&2
  exit 1
}

if command -v magick >/dev/null 2>&1; then
  im=(magick)
elif command -v convert >/dev/null 2>&1; then
  im=(convert)
else
  echo "Error: ImageMagick not found (magick/convert)" >&2
  exit 1
fi

dir="$(dirname "$in")"
base="$(basename "$in")"
name="${base%.*}"
out="${dir}/${name}.optimized.jpg"

"${im[@]}" "$in" \
  -auto-orient \
  -sampling-factor 4:2:0 \
  -strip \
  -resize "${width}x>" \
  -quality "$quality" \
  -interlace JPEG \
  "$out"

echo "Wrote: $out"
